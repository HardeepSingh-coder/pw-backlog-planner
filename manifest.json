{
  "manifest_version": 3,
  "name": "PW Backlog Auto-Sync Tool",
  "version": "1.0",
  "description": "Automatically scrapes and syncs your Physics Wallah backlogs with your study planner.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.pw.live/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.pw.live/*",
        "http://localhost:8080/*",
        "http://127.0.0.1:8080/*",
        "https://*.vercel.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}
